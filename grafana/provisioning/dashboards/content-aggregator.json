{
    "title": "Content Aggregator Metrics",
    "uid": "aggregator-metrics",
    "schemaVersion": 36,
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
        {
            "type": "timeseries",
            "title": "HTTP Requests Rate (5m)",
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "rate(http_requests_total[5m])",
                    "legendFormat": "{{method}} {{route}} - {{status_code}}"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "HTTP Request Duration 95th Percentile",
            "gridPos": {
                "x": 12,
                "y": 0,
                "w": 12,
                "h": 8
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route, method))",
                    "legendFormat": "{{method}} {{route}}"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Articles Fetched (Rate 5m)",
            "gridPos": {
                "x": 0,
                "y": 8,
                "w": 8,
                "h": 8
            },
            "targets": [
                {
                    "expr": "rate(articles_fetched_total[5m])",
                    "legendFormat": "{{source}}"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "API Fetch Retries (Rate 5m)",
            "gridPos": {
                "x": 8,
                "y": 8,
                "w": 8,
                "h": 8
            },
            "targets": [
                {
                    "expr": "rate(fetch_retries_total[5m])",
                    "legendFormat": "{{source}}"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "API Fetch Failures (Total)",
            "gridPos": {
                "x": 16,
                "y": 8,
                "w": 8,
                "h": 8
            },
            "targets": [
                {
                    "expr": "fetch_failures_total",
                    "legendFormat": "{{source}} - {{error_type}}"
                }
            ]
        }
    ]
}